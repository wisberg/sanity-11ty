  <section class="page-shell components-page">
  <h1>Component Library</h1>
  <p>Use these in Sanity's page builder array to compose new pages.</p>

  <div class="component-section" id="hero">
  <h2>Hero</h2>
  {% set block = {
    "_type": "hero",
    "eyebrow": "Sample",
    "heading": "Hero Heading",
    "subheading": "A short supporting message.",
    "imageUrl": "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80",
    "imageAlt": "Landscape",
    "imagePosition": "left"
  } %}
  {% include "components/hero.njk" %}
  </div>

  <div class="component-section" id="full-width-hero">
  <h2>Full Width Hero</h2>
  {% set block = {
    "_type": "fullWidthHero",
    "eyebrow": "Product launch",
    "heading": "A full-width hero built for modern brands",
    "subheading": "Use bold imagery, layered overlays, and clear CTAs to make the first impression count.",
    "primaryLabel": "Start now",
    "primaryLinkType": "external",
    "primaryExternalUrl": "https://www.sanity.io",
    "secondaryLabel": "See components",
    "secondaryLinkType": "external",
    "secondaryExternalUrl": "/components/",
    "backgroundUrl": "https://images.unsplash.com/photo-1487014679447-9f8336841d58?auto=format&fit=crop&w=1600&q=80"
  } %}
  {% include "components/fullWidthHero.njk" %}
  </div>


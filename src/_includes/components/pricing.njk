<section class="component pricing">
  {% if block.heading %}<h2>{{ block.heading }}</h2>{% endif %}
  {% if block.subheading %}<p class="lead">{{ block.subheading }}</p>{% endif %}
  {% if block.plans and block.plans.length %}
    <div class="pricing-grid">
      {% for plan in block.plans %}
        <div class="pricing-card{% if plan.featured %} featured{% endif %}">
          <h3>{{ plan.name }}</h3>
          {% if plan.price %}<div class="pricing-price">{{ plan.price }}</div>{% endif %}
          {% if plan.description %}<p class="muted">{{ plan.description }}</p>{% endif %}
          {% if plan.features and plan.features.length %}
            <ul class="pricing-features">
              {% for feature in plan.features %}
                <li>{{ feature }}</li>
              {% endfor %}
            </ul>
          {% endif %}
          {% if plan.ctaUrl %}
            <a class="button{% if not plan.featured %} ghost{% endif %}" href="{{ plan.ctaUrl }}">
              {{ plan.ctaLabel or "Choose plan" }}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}
</section>
